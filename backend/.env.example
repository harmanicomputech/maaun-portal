# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string — works with Railway, Render, Supabase, or any
# managed PostgreSQL provider.
DATABASE_URL=postgresql://user:password@localhost:5432/maaun_db

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Secret key used to sign JWT tokens. Generate a strong random value for
# production: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=change-me-in-production

# ─── Payments ─────────────────────────────────────────────────────────────────
# Paystack secret key from https://dashboard.paystack.com/#/settings/developers
# Leave empty to run in test mode (payments initialized but not sent to Paystack).
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Frontend ─────────────────────────────────────────────────────────────────
# The full URL of your deployed frontend — used as the Paystack payment
# callback redirect URL (e.g. https://your-app.vercel.app).
# Leave empty during local development (falls back to http://localhost:5173).
APP_URL=

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Set this to your frontend origin to restrict CORS in production.
# Leave empty to allow all origins (fine for development).
# Example: https://your-app.vercel.app
FRONTEND_URL=
