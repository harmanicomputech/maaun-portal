# ─── API ──────────────────────────────────────────────────────────────────────
# Base URL of the backend API server.
# • Local development: http://localhost:3000 (backend runs on port 3000)
# • Production: https://your-backend.railway.app  or  https://api.yourdomain.com
#
# Leave empty ("") if the frontend is served from the same origin as the
# backend (e.g. a reverse-proxy setup where /api is routed to the backend).
VITE_API_URL=http://localhost:3000
